{
  "name": "ai-agent-migrate",
  "version": "0.1.0",
  "description": "AI-driven code migration CLI tool with AST + LLM hybrid strategy",
  "main": "dist/index.js",
  "bin": {
    "ai-agent-migrate": "./bin/ai-agent-migrate.js"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "README.md",
    "README_EN.md",
    "LICENSE"
  ],
  "scripts": {
    "preinstall": "node scripts/preinstall.js",
    "postinstall": "node scripts/postinstall.js",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "migration",
    "ast",
    "llm",
    "vue",
    "react",
    "typescript",
    "codemod"
  ],
  "author": "peterfei",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "@anthropic-ai/sdk": "^0.27.0",
    "openai": "^4.0.0",
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/generator": "^7.24.0",
    "@babel/types": "^7.24.0",
    "jscodeshift": "^0.15.0",
    "ts-morph": "^21.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "glob": "^10.0.0",
    "fs-extra": "^11.0.0",
    "zod": "^3.22.0",
    "simple-git": "^3.22.0",
    "semver": "^7.6.0",
    "diff": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "@types/inquirer": "^9.0.0",
    "@types/babel__traverse": "^7.20.0",
    "@types/fs-extra": "^11.0.0",
    "@types/diff": "^5.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/peterfei/ai-agent-migrate.git"
  },
  "bugs": {
    "url": "https://github.com/peterfei/ai-agent-migrate/issues"
  },
  "homepage": "https://github.com/peterfei/ai-agent-migrate#readme"
}
